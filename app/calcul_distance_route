import requests
import time

API_KEY = "TA_CLE_API"

def get_coords(city):
    """Convertit une ville en coordonnées GPS"""
    url = "https://api.openrouteservice.org/geocode/search"
    
    params = {
        "api_key": API_KEY,
        "text": city,
        "size": 1
    }

    response = requests.get(url, params=params)
    data = response.json()

    coords = data["features"][0]["geometry"]["coordinates"]
    return coords  # [lon, lat]


def get_distance(city1, city2):
    """Calcule distance + durée + CO2"""
    
    coords1 = get_coords(city1)
    coords2 = get_coords(city2)

    url = "https://api.openrouteservice.org/v2/directions/driving-car"

    headers = {
        "Authorization": API_KEY,
        "Content-Type": "application/json"
    }

    body = {
        "coordinates": [coords1, coords2]
    }

    response = requests.post(url, json=body, headers=headers)
    data = response.json()

    segment = data["features"][0]["properties"]["segments"][0]

    distance_km = segment["distance"] / 1000
    duration_h = segment["duration"] / 3600

    # estimation CO2 (voiture thermique moyenne)
    co2 = distance_km * 0.18

    return distance_km, duration_h, co2


def compute_all(trajets):
    results = []

    for origine, destination in trajets:
        try:
            distance, duration, co2 = get_distance(origine, destination)

            results.append({
                "origine": origine,
                "destination": destination,
                "distance_km": round(distance, 2),
                "duration_h": round(duration, 2),
                "co2_kg": round(co2, 2)
            })

            print(f"OK: {origine} → {destination}")

            time.sleep(1)  # éviter rate limit

        except Exception as e:
            print(f"Erreur: {origine} → {destination} :", e)

    return results


# Exemple d'utilisation
trajets = [
    ("Paris", "Marseille"),
    ("Lyon", "Bordeaux"),
    ("Lille", "Nice")
]

data = compute_all(trajets)

# Affichage
for row in data:
    print(row)